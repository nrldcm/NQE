# Flutter/Dart
.dart_tool/
.packages
build/
.flutter-plugins
.flutter-plugins-dependencies
# pubspec.lock IS committed (app, not package) for reproducible CI builds.

# Platform folders are regenerated in CI via `flutter create .`
# Anchored to the repo root so they don't also match the bundled web build
# staged under assets/web/ (which must be trackable for local `flutter pub get`).
/android/
/ios/
/linux/
/macos/
/windows/
/web/

# IDE / OS
.idea/
.vscode/
*.iml
.DS_Store

# Secrets / keystores
*.keystore
*.jks
key.properties
